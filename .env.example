# Faro configuration — copy to .env
# Everything is OPTIONAL: with no key set, the copilot uses local Ollama automatically.

# Anthropic API (primary LLM when set) — get a key at console.anthropic.com
ANTHROPIC_API_KEY=
# ANTHROPIC_MODEL=claude-sonnet-5

# Ollama fallback (local, free) — install from ollama.com, then: ollama pull qwen2.5:7b
# OLLAMA_URL=http://localhost:11434
# OLLAMA_MODEL=qwen2.5:7b

# Quant assumptions
# RISK_FREE_RATE=0.043
# BENCHMARK_TICKER=SPY
